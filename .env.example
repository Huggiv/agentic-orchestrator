# Jira settings
JIRA_URL=https://your-onprem-jira-host
JIRA_PAT=your-jira-personal-access-token
JIRA_VERIFY_SSL=false

# GitHub token is used for gh CLI, gh copilot CLI, and PR creation.
GITHUB_TOKEN=ghp_xxx

# Copilot CLI token for headless execution.
# Must be a token that supports Copilot Requests (fine-grained PAT) or a valid OAuth token.
# Keep this distinct from GITHUB_TOKEN when the repository PAT does not include Copilot permission.
COPILOT_GITHUB_TOKEN=gho_xxx

# Optional: bot identity for commits created by orchestration.
GIT_AUTHOR_NAME=AGENT_FLOW Agentic Bot
GIT_AUTHOR_EMAIL=agent_flow-bot@example.com

# Optional: host paths for Docker bind mounts (defaults to ${HOME}/... when unset).
# AGENT_FLOW_HOST_REPO_DIR=/Users/your-user/agent_flow-tmp-repos
# AGENT_FLOW_HOST_HISTORY_DIR=/Users/your-user/agent_flow-history
# AGENT_FLOW_HOST_COPILOT_STATE_DIR=/Users/your-user/.copilot/agentic-orch
